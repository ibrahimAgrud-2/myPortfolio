<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Portfolio</title>
 
   <link rel="icon" href="icon/AGRUD.ico" type="icon/fav.ico">

       <link rel="stylesheet" href="~/css/pageStyle.css" />

     <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css">
</head>
<body style="background-color: black; color: white;">


    <header>
      <nav class="navbar navbar-expand-lg fs-2">
        <!--Her bir bölüm container class'i içine aldık. Bu sayede hizalama vs kolay oluyor.-->
        <div class="container">
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent"
                aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                <!---Menu icon SVG hali-->
                <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3"><path d="M120-240v-80h720v80H120Zm0-200v-80h720v80H120Zm0-200v-80h720v80H120Z"/></svg>
            </button>

            <div>
                <!--Text white ile logoyu beyaz yaptık. Zaten logo'da bir text olduğu için çalıştı-->
                <a class="bi bi-linkedin text-white" href="https://www.linkedin.com/in/ibrahimagrud/?locale=en"></a>
                <a class="bi bi-github text-white" href="https://github.com/ibrahimAgrud-2"></a>
            </div>

            <div class="collapse navbar-collapse" id="navbarSupportedContent">
            <!---ms-auto BS hizalama classı-->
            <ul class="navbar-nav navbar-text ms-auto">
                <li class="nav-item"><a class="text-white text-decoration-none" href="#Education">Education</a></li>
                <li class="nav-item"><a class="text-white text-decoration-none " href="#Skills">Skills</a></li>
                <li class="nav-item"><a class="text-white text-decoration-none" href="#Projects">Projects</a></li>
                <li class="nav-item"><a class="text-white text-decoration-none" href="#Resume">Resume</a></li>
                <li class="nav-item"><a class="text-white text-decoration-none" href="#Contact">Contact</a></li>
            </ul>
            </div>

        </div>
    </nav>
    </header>




    <div>
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

  


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>



